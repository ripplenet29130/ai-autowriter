+function isLikelyBodyLine(line: string): boolean {
+  const text = String(line || '').trim();
+  if (!text) return false;
+  if (isHeadingLine(text)) return false;
+  if (/^[-*+]\s|^\d+[.)]\s|^[・●■]\s?/.test(text)) return true;
+  return text.length >= 20 || /[。！？.!?、]/.test(text);
