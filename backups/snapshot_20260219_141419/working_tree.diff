+  type HeadingSection = {
+    lineIndex: number;
+    level: number;
+    title: string;
+    bodySnippet: string;
+  };
+
+  function normalizeHeadingComparableText(text: string): string {
+    return String(text || '')
+      .toLowerCase()
+      .replace(/[「」『』【】"'`]/g, '')
+      .replace(/[｜|:：\-‐‑–—]/g, '')
+      .replace(/\s+/g, '')
